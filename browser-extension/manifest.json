{
  "manifest_version": 3,
  "name": "Jarvis Browser Bridge",
  "version": "1.0.0",
  "description": "Optional, user-approved browser control for the local Jarvis macOS app.",
  "key": "",
  "permissions": ["nativeMessaging", "tabs", "scripting", "storage"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": { "service_worker": "service-worker.js" },
  "action": { "default_popup": "popup.html", "default_title": "Jarvis Browser Bridge" }
}
