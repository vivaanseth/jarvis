{
  "name": "jarvis-desktop",
  "version": "1.3.7",
  "private": true,
  "productName": "Jarvis",
  "description": "Open-source, private-first desktop assistant with local automation and bring-your-own AI",
  "author": "Vivaan Seth <vivaanseth@users.noreply.github.com>",
  "license": "MIT",
  "keywords": [
    "macos",
    "assistant",
    "electron",
    "swift",
    "ollama",
    "automation",
    "privacy"
  ],
  "engines": {
    "node": ">=24"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "package": "./script/package_electron.sh",
    "package:release": "node script/prepare_release_assets.cjs && electron-builder --publish never",
    "test": "node --test electron/tests/*.test.cjs",
    "check": "./script/check_js.sh && ./script/check_secrets.sh",
    "security:secrets": "./script/check_secrets.sh"
  },
  "devDependencies": {
    "electron": "43.0.0",
    "electron-builder": "26.0.12"
  },
  "build": {
    "appId": "com.local.Jarvis",
    "productName": "Jarvis",
    "asar": true,
    "directories": { "buildResources": "build-resources", "output": "release-dist" },
    "files": ["electron/**/*", "package.json", "!electron/tests/**/*", "!electron/entitlements.plist", "!**/.DS_Store"],
    "extraResources": [
      { "from": "browser-extension", "to": "browser-extension", "filter": ["**/*"] },
      { "from": "electron/browser-host.cjs", "to": "browser-host.cjs" },
      { "from": "build-resources/native", "to": "native", "filter": ["**/*"] }
    ],
    "artifactName": "Jarvis-${version}-${os}-${arch}.${ext}",
    "mac": { "category": "public.app-category.productivity", "icon": "build-resources/icon.icns", "target": ["dmg", "zip", "tar.gz"], "hardenedRuntime": true, "gatekeeperAssess": false, "x64ArchFiles": "Contents/Resources/native/JarvisNativeBridge" },
    "dmg": { "title": "Jarvis ${version}" },
    "win": { "icon": "build-resources/icon.ico", "target": ["nsis", "msi"] },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "artifactName": "Jarvis-${version}-windows-${arch}-setup.${ext}" },
    "msi": { "artifactName": "Jarvis-${version}-windows-${arch}.${ext}" },
    "linux": { "category": "Utility", "icon": "build-resources/icon.png", "maintainer": "Vivaan Seth <vivaanseth@users.noreply.github.com>", "target": ["AppImage", "deb", "rpm", "tar.gz"] }
  }
}
