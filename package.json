{
  "name": "jarvis-desktop",
  "version": "1.3.0",
  "private": true,
  "productName": "Jarvis",
  "description": "Open-source, private-first macOS desktop assistant with local automation and bring-your-own AI",
  "license": "MIT",
  "keywords": ["macos", "assistant", "electron", "swift", "ollama", "automation", "privacy"],
  "engines": { "node": ">=20" },
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "package": "./script/package_electron.sh",
    "test": "node --test electron/tests/*.test.cjs",
    "check": "./script/check_js.sh && ./script/check_secrets.sh",
    "security:secrets": "./script/check_secrets.sh"
  },
  "devDependencies": {
    "electron": "43.0.0"
  }
}
